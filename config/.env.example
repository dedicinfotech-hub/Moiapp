# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=moiapp

# ── App ───────────────────────────────────────────────────────────────────────
# Full URL where the PHP backend lives (no trailing slash)
APP_URL=https://dsitesai.com/moiapp

# Allowed frontend origin for CORS (no trailing slash)
CORS_ORIGIN=https://dsitesai.com

# ── Mail (SMTP) ────────────────────────────────────────────────────────────────
# For OTP emails and notifications. Leave empty to use PHP mail() fallback.
MAIL_FROM_EMAIL=noreply@moiapp.com
MAIL_FROM_NAME=MoiApp
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=your-email@gmail.com
MAIL_SMTP_PASS=your-app-password
MAIL_SMTP_SECURE=tls

# ── AWS S3 (optional – only needed if using photo uploads) ────────────────────
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=ap-south-1
AWS_BUCKET=moiapp-photos
